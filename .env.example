# === 通知渠道（填了即启用，不填则跳过） ===

# 企业微信群机器人 Webhook
WECOM_WEBHOOK_URL=

# 飞书群机器人 Webhook
FEISHU_WEBHOOK_URL=

# 钉钉群机器人 Webhook
DINGTALK_WEBHOOK_URL=
# 钉钉签名密钥（可选，如果开启了加签验证则填写）
DINGTALK_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === 搜索配置 ===

# 搜索关键词，逗号分隔（如: android,kotlin,flutter）
JOB_SEARCH_KEYWORDS=android

# 调度间隔（分钟），默认 30
JOB_SCHEDULE_INTERVAL=30

# === 代理（配了就走代理，不配则直连） ===

# HTTP/HTTPS 代理（如: http://127.0.0.1:7890）
HTTP_PROXY=
HTTPS_PROXY=

# SOCKS5 代理（如: socks5://127.0.0.1:7891）
# 优先级高于 HTTP 代理
SOCKS_PROXY=

# === 职位筛选（不填则不筛选，全部通过） ===

# 期望工作地区，逗号分隔（如: 北京,上海,深圳）
JOB_FILTER_LOCATIONS=

# 是否只看远程职位: true/false（默认 false）
JOB_FILTER_REMOTE=false

# 排除包含这些词的职位，逗号分隔（如: 实习,兼职）
JOB_FILTER_EXCLUDE_WORDS=

# 职位标题/描述必须包含这些词之一，逗号分隔
JOB_FILTER_INCLUDE_WORDS=

# 最低薪资（数字，单位K，如: 15 表示 15K）
JOB_FILTER_MIN_SALARY=

# 排除的公司名，逗号分隔
JOB_FILTER_COMPANIES_EXCLUDE=
